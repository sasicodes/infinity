generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id String @id @default(uuid())

  html     String?
  content  String?
  mediaUrl String?

  ipId           String
  tokenId        String?
  licenseTermsId String?
  hasLicense     Boolean @default(false)
  userId         String
  nodeId         String
  username       String
  category       String  @default("any")

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model Flow {
  id String @id

  flow   String // JSON stringified Edge[] and Node[]
  userId String

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([userId])
}

model Node {
  id String @id

  flowId String
  userId String
  node   String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}
